
# 赛博印钞机 Pro 环境配置模板
# 请填写以下配置，保存后重命名为 .env，重启应用

# ================= Trae配置 =================
# Trae API Key，在Trae IDE的设置中获取
TRAE_API_KEY=你的Trae API Key

# ================= Notion配置 =================
# Notion API Token，在Notion开发者平台创建
NOTION_TOKEN=你的Notion API Token
# Notion数据库ID，从数据库链接中获取
NOTION_DATABASE_ID=你的Notion数据库ID

# ================= GitHub配置 =================
# GitHub Personal Access Token，需要repo权限
GITHUB_TOKEN=你的GitHub Personal Access Token
# GitHub仓库地址，格式：用户名/仓库名
GITHUB_REPO=你的GitHub仓库地址

# ================= 系统配置 =================
# 系统日志路径（不用改，自动生成）
SYSTEM_LOG_PATH=logs/system.log
