# 赛博印钞机 Pro 环境配置
# 复制此文件为 .env 并填写你的配置

# ================= 通用LLM配置（兼容所有OpenAI格式接口） =================
# 你的API Key（Claude/GPT/开源模型/其他兼容接口都用这个）
LLM_API_KEY=你的API_Key
# 接口地址（默认Claude官方，可换成本地Ollama、其他兼容接口）
LLM_BASE_URL=https://api.anthropic.com/v1/
# 模型名称（默认Claude，可换成任意兼容模型）
LLM_MODEL_NAME=claude-3-5-sonnet-20240620
# 模型调用超时时间（秒）
LLM_TIMEOUT=300
# 模型温度系数（0-1，越高越随机）
LLM_TEMPERATURE=0.7

# ================= Notion配置（可选） =================
NOTION_TOKEN=你的Notion API Token
NOTION_DATABASE_ID=你的Notion数据库ID

# ================= GitHub配置（可选） =================
GITHUB_TOKEN=你的GitHub Personal Access Token
GITHUB_REPO=你的GitHub仓库地址（格式：用户名/仓库名）

# ================= 守护进程配置 =================
# 每日自动生成时间（小时）
DAEMON_GEN_HOUR=3
