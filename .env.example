# =============================================
# 赛博印钞机 Pro V2.4 环境变量配置模板
# 复制此文件为 .env 并填写你的配置
# 支持所有符合 OpenAI 标准的大模型（Claude/GPT/DeepSeek/豆包/通义千问/本地开源模型）
# 【Deer-Flow 2.0 成本优化建议】
# 主脑用：deepseek-chat / DeepSeek-R1 (逻辑推理强，0.1元/百万Token
# 写手用：MiniMax-M2.5 / doubao-pro (网文语感好，性价比高
# =============================================

# ================= 核心大模型配置（必填） =================
# 你的大模型 API Key
LLM_API_KEY=你的大模型_API_Key
# 大模型接口地址（绝大多数服务商必须以 /v1 结尾）
# 优先级：API_BASE_URL > LLM_BASE_URL > OPENAI_BASE_URL
# 官方示例：
# OpenAI: https://api.openai.com/v1
# Anthropic Claude: https://api.anthropic.com/v1
# DeepSeek: https://api.deepseek.com/v1
# 字节豆包: https://ark.cn-beijing.volces.com/api/v1
# 本地Ollama: http://localhost:11434/v1
# 中转池（推荐，统一OpenAI格式：https://api.你的中转池.com/v1
API_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://api.openai.com/v1

# ========== 主脑（调度层）配置 ==========
# 主脑负责任务调度、不亲自写网文，推荐逻辑强的模型
# 推荐：deepseek-chat、DeepSeek-R1、gpt-4o-mini
# 成本：DeepSeek-R1 约 0.1元/百万Token
ORCHESTRATOR_MODEL=deepseek-chat
ORCHESTRATOR_TEMPERATURE=0.3
# 主脑API Key（可选，不填则使用LLM_API_KEY）
# ORCHESTRATOR_API_KEY=你的主脑_API_Key
# 主脑API地址（可选，不填则使用API_BASE_URL）
# ORCHESTRATOR_BASE_URL=https://api.主脑中转池.com/v1

# ========== 写手（创作层）配置 ==========
# 写手负责实际写网文，推荐语感好、性价比高的模型
# 推荐：MiniMax-M2.5、doubao-pro-32k、deepseek-chat
# 成本：MiniMax-M2.5 性价比极高
WRITER_MODEL=MiniMax-M2.5
WRITER_TEMPERATURE=0.8
# 写手API Key（可选，不填则使用LLM_API_KEY）
# WRITER_API_KEY=你的写手_API_Key
# 写手API地址（可选，不填则使用API_BASE_URL）
# WRITER_BASE_URL=https://api.写手中转池.com/v1

# ========== 备用配置（向后兼容） ==========
# 模型名称（根据你的服务商填写）
# 【成本优化推荐配置】
# 主脑（调度）推荐：deepseek-chat、DeepSeek-R1、gpt-4o-mini
# 写手（创作）推荐：MiniMax-M2.5、doubao-pro-32k、deepseek-chat
# 示例：gpt-4o、claude-3-5-sonnet-20241022、deepseek-chat、doubao-pro-32k
LLM_MODEL_NAME=gpt-4o
# 模型调用超时时间（秒）
LLM_TIMEOUT=300
# 模型温度系数（0-1，越高越随机，网文创作推荐0.7-0.8）
LLM_TEMPERATURE=0.7
# 单轮最大输出Token数
LLM_MAX_TOKENS=16384
# 生成最大重试次数
MAX_RETRY=3

# ================= 自动分发配置（可选） =================
# Notion 自动分发配置
NOTION_TOKEN=你的_Notion_API_Token
NOTION_DATABASE_ID=你的_Notion_数据库_ID

# GitHub 自动归档配置
GITHUB_TOKEN=你的_GitHub_Personal_Access_Token
GITHUB_REPO=你的_GitHub仓库地址（格式：用户名/仓库名）

# ================= 守护进程配置（可选） =================
# 每日自动生成时间（小时，24小时制）
DAEMON_GEN_HOUR=3
# 每日自动生成章节数
DAEMON_CHAPTERS_PER_DAY=1
# 单章默认目标字数
DAEMON_DEFAULT_WORDS=7500

# ================= 功能开关配置（可选） =================
# 卧底模式开关（true/false）
UNDERCOVER_MODE_ENABLED=true
# 卧底模式严格程度（low/medium/high）
UNDERCOVER_MODE_STRICTNESS=medium
# 记忆系统自动更新开关（true/false）
MEMORY_AUTO_UPDATE=true
